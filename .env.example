# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=production
FLASK_DEBUG=0

# Site Configuration
SITE_URL=https://tools.292029.xyz
SITE_NAME=办公效率工具集

# Upload Configuration
MAX_CONTENT_LENGTH=524288000  # 500MB in bytes

# Cleanup Configuration
CLEANUP_INTERVAL=600  # 10 minutes
FILE_EXPIRE_SECONDS=1800  # 30 minutes

# Rate Limiting
RATE_LIMIT_DEFAULT=10 per minute
RATE_LIMIT_UPLOAD=5 per minute

# OCR Configuration
OCR_MAX_FILE_BYTES=52428800  # 50MB
OCR_MAX_PAGES=100